{
  "name": "multi-agent-coordinator",
  "version": "1.0.0",
  "description": "Powerful multi-agent parallel execution and visualization tool for OpenClaw",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "mac": "./bin/multi-agent-server.js"
  },
  "scripts": {
    "start": "node bin/start.js",
    "server": "node bin/multi-agent-server.js",
    "dev": "cd web-ui && npm run dev",
    "build": "cd web-ui && npm run build",
    "test": "node bin/test-api.js && node bin/test-integration.js",
    "clean": "rm -rf web-ui/dist node_modules"
  },
  "keywords": [
    "openclaw",
    "multi-agent",
    "ai",
    "automation",
    "visualization",
    "workflow",
    "react",
    "nodejs"
  ],
  "author": "yijianw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yijianw/Multi-Agent-Coordinator.git"
  },
  "bugs": {
    "url": "https://github.com/yijianw/Multi-Agent-Coordinator/issues"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
